// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// ================================
//   DATABASE PROVIDER & CLIENT
// ================================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================
//           ENUMS
// ================================

enum MovementType {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum OrderStatus {
  PENDING
  PARTIAL
  COMPLETED
  CANCELLED
}

// ================================
//           MODELS
// ================================

// PRODUCTS
model Product {
  id          Int       @id @default(autoincrement())
  name        String
  brand       String?
  category    String?
  barcode     String?   @unique
  description String?
  createdAt   DateTime  @default(now())

  batches     Batch[]
  orderItems  OrderItem[]
  stockMoves  StockMovement[]
}

// BATCHES (Important in pharmaceuticals)
model Batch {
  id          Int       @id @default(autoincrement())
  productId   Int
  batchNumber String
  expiryDate  DateTime
  quantity    Int       @default(0)

  product     Product   @relation(fields: [productId], references: [id])
  stockMoves  StockMovement[]

  @@index([productId])
}

// STORAGE LOCATIONS
model Location {
  id     Int     @id @default(autoincrement())
  name   String
  locationType   String   // e.g., shelf, main warehouse, cold room, quarantine

  stockMovesFrom StockMovement[] @relation("MoveFrom")
  stockMovesTo   StockMovement[] @relation("MoveTo")
}

// STOCK MOVEMENTS LOG
model StockMovement {
  id            Int          @id @default(autoincrement())
  productId     Int
  batchId       Int?
  fromLocationId Int?
  toLocationId   Int?
  quantity      Int
  movementType  MovementType
  timestamp     DateTime     @default(now())

  product     Product   @relation(fields: [productId], references: [id])
  batch       Batch?    @relation(fields: [batchId], references: [id])
  fromLocation Location? @relation("MoveFrom", fields: [fromLocationId], references: [id])
  toLocation   Location? @relation("MoveTo", fields: [toLocationId], references: [id])

  @@index([productId])
  @@index([batchId])
  @@index([fromLocationId])
  @@index([toLocationId])
}

// SUPPLIERS
model Supplier {
  id       Int     @id @default(autoincrement())
  name     String
  email    String?
  phone    String?

  orders   Order[]
}

// PURCHASE ORDERS
model Order {
  id          Int          @id @default(autoincrement())
  supplierId  Int
  status      OrderStatus  @default(PENDING)
  createdAt   DateTime     @default(now())

  supplier    Supplier     @relation(fields: [supplierId], references: [id])
  items       OrderItem[]
}

// ITEMS INSIDE A PURCHASE ORDER
model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int

  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// USERS (AUTH)
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}
